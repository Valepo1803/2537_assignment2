<%- include("templates/header") %>

<div class="p-5 mb-4 bg-white rounded-3 shadow-sm border text-center">
    <div class="container-fluid py-5">
        <% if (user) { %>
            <h1 class="display-5 fw-bold">Welcome, <%= user %>!</h1>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                <a href="/members" class="btn btn-primary btn-lg px-4">Members Area</a>
                <a href="/signout" class="btn btn-outline-secondary btn-lg px-4">Sign Out</a>
            </div>
        <% } else { %>
            <h1 class="display-5 fw-bold">Welcome to Assignment 2</h1>
            <p class="fs-4 text-muted">Please log in or sign up to continue.</p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                <a href="/signup" class="btn btn-success btn-lg px-4 gap-3">Sign Up</a>
                <a href="/login" class="btn btn-primary btn-lg px-4">Log In</a>
            </div>
        <% } %>
    </div>
</div>

<%- include("templates/footer") %>