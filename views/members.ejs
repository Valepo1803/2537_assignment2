<%- include("templates/header") %>

<div class="text-center">
    <h1 class="display-4 fw-bold mb-4">Hello, <%= username %>!</h1>
    <p class="lead mb-5">Welcome to the exclusive members area.</p>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="/cat-1.jpg" class="card-img-top" alt="Member Image 1">
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="/cat-2.jpg" class="card-img-top" alt="Member Image 2">
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="/cat-3.jpg" class="card-img-top" alt="Member Image 3">
            </div>
        </div>
    </div>

    <div class="mt-5">
        <a href="/signout" class="btn btn-outline-danger">Sign Out</a>
    </div>
</div>

<%- include("templates/footer") %>